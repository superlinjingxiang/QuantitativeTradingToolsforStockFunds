{
  "name": "china-quant-platform-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for the China Quant Platform Python backend.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "electron": "electron .",
    "frontend:dev": "vite --config frontend/vite.config.ts --host 127.0.0.1",
    "build": "vite build --config frontend/vite.config.ts",
    "test:unit": "vitest --config frontend/vitest.config.ts",
    "test:e2e": "playwright test --config frontend/playwright.config.ts",
    "electron:dev": "concurrently -k \"npm:frontend:dev\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "electron:build": "npm run build && electron ."
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
