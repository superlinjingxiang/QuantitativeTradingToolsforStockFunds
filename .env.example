CQP_ENVIRONMENT=development
CQP_LOG_LEVEL=INFO
CQP_DATA_DIR=data
CQP_LOGS_DIR=logs
CQP_REPORTS_DIR=reports

# Provider credentials must be supplied by environment variables, a local ignored
# .env file, or the operating system credential store. Do not commit real values.
CQP_DATA_PROVIDER_API_KEY=

# 同花顺 iFinD / QuantAPI 可选配置：
# 获取 refresh_token：同花顺超级命令客户端 -> 工具 -> refresh_token 查询；
# 或网页版超级命令 -> 账号详情。不要提交真实 token。
# 是否收费取决于你的同花顺 iFinD/QuantAPI 账号权限；普通同花顺App账号
# 不等同于已开通数据API。
CQP_THS_IFIND_REFRESH_TOKEN=
CQP_THS_IFIND_BASE_URL=https://quantapi.51ifind.com/api/v1
CQP_THS_IFIND_TIMEOUT_SECONDS=10
CQP_THS_IFIND_POLL_SECONDS=5

# ai-hedge-fund 独立研究入口（可选）：不替换本项目内置策略。
# 先单独 clone https://github.com/virattt/ai-hedge-fund.git，并在该仓库安装依赖。
CHINA_QUANT_AI_HEDGE_FUND_PATH=

# ai-hedge-fund 自身需要 Financial Datasets 数据 key，以及至少一个 LLM key；
# 使用 --ollama 时仍通常需要 FINANCIAL_DATASETS_API_KEY 获取美股数据。
FINANCIAL_DATASETS_API_KEY=
OPENAI_API_KEY=
