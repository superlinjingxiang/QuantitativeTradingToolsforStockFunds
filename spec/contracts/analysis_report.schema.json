{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/analysis-report.schema.json",
  "title": "分析报告",
  "type": "object",
  "required": [
    "security_id",
    "as_of",
    "data_health",
    "strategy_id",
    "strategy_version",
    "horizon",
    "market_regime",
    "direction_probabilities",
    "raw_signal",
    "final_signal",
    "valid_until",
    "positive_drivers",
    "negative_drivers",
    "model_version",
    "rule_version",
    "data_snapshot_id"
  ],
  "properties": {
    "security_id": {
      "type": "string",
      "minLength": 1,
      "description": "证券唯一标识。"
    },
    "as_of": {
      "type": "string",
      "format": "date-time",
      "description": "分析使用数据的时点时间。"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time",
      "description": "分析结果有效截止时间。"
    },
    "data_health": {
      "$ref": "data-health.schema.json",
      "description": "数据健康状态。"
    },
    "strategy_id": {
      "type": "string",
      "description": "策略标识。"
    },
    "strategy_version": {
      "type": "string",
      "description": "策略版本。"
    },
    "model_version": {
      "type": "string",
      "description": "模型版本。"
    },
    "rule_version": {
      "type": "string",
      "description": "交易规则版本。"
    },
    "data_snapshot_id": {
      "type": "string",
      "description": "数据快照标识。"
    },
    "horizon": {
      "type": "integer",
      "minimum": 1,
      "description": "概率预测终点周期，当前日线模型单位为交易日。"
    },
    "strategy_horizon": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "description": "策略持有或回测窗口；与概率预测终点周期分开。"
    },
    "market_regime": {
      "type": "string",
      "description": "市场状态。"
    },
    "direction_probabilities": {
      "type": "object",
      "required": [
        "up",
        "flat",
        "down"
      ],
      "properties": {
        "up": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "flat": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "down": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false,
      "description": "上涨、横盘和下跌概率。"
    },
    "expected_return_quantiles": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      },
      "description": "预期收益分位数。"
    },
    "expected_drawdown": {
      "type": [
        "number",
        "null"
      ],
      "description": "预期回撤。"
    },
    "forecast_validation": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "sample_count": {"type": "integer", "minimum": 0},
        "required_sample_count": {"type": "integer", "minimum": 1},
        "candidate_count": {"type": "integer", "minimum": 0},
        "evaluation_stride": {"type": "integer", "minimum": 1},
        "training_embargo": {"type": "integer", "minimum": 0},
        "interval_coverage": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "downside_breach_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "direction_brier_score": {"type": ["number", "null"], "minimum": 0}
      },
      "required": [
        "sample_count",
        "required_sample_count",
        "candidate_count",
        "evaluation_stride",
        "training_embargo",
        "interval_coverage",
        "downside_breach_rate",
        "direction_brier_score"
      ],
      "additionalProperties": false,
      "description": "清除持有期重叠后的预测校准证据。"
    },
    "portfolio_strategy_evidence": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "security_id": {"type": "string", "minLength": 1},
        "strategy_id": {"type": "string", "minLength": 1},
        "strategy_version": {"type": "string", "minLength": 1},
        "validation_status": {"type": "string", "minLength": 1},
        "as_of_date": {"type": "string", "format": "date"},
        "signal_date": {"type": ["string", "null"], "format": "date"},
        "execution_date": {"type": ["string", "null"], "format": "date"},
        "selected_security_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "current_security_selected": {"type": "boolean"},
        "current_security_rank": {"type": ["integer", "null"], "minimum": 1},
        "current_security_momentum": {"type": ["number", "null"]},
        "target_position_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "current_security_target_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "bars_until_next_rebalance": {"type": ["integer", "null"], "minimum": 1},
        "base_total_return": {"type": ["number", "null"]},
        "stress_total_return": {"type": ["number", "null"]},
        "excess_return": {"type": ["number", "null"]},
        "max_drawdown": {"type": ["number", "null"], "maximum": 0},
        "sharpe_ratio": {"type": ["number", "null"]},
        "walk_forward_fold_count": {"type": "integer", "minimum": 0},
        "required_walk_forward_fold_count": {"type": "integer", "minimum": 1},
        "walk_forward_positive_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "walk_forward_excess_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "cumulative_turnover": {"type": ["number", "null"], "minimum": 0},
        "average_rebalance_turnover": {"type": ["number", "null"], "minimum": 0, "maximum": 2},
        "cumulative_transaction_cost": {"type": ["number", "null"], "minimum": 0},
        "trading_system": {"type": "string", "minLength": 1},
        "capacity_status": {"type": "string", "minLength": 1},
        "capacity_model_version": {"type": "string", "minLength": 1},
        "capacity_reference_capital": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "capacity_max_participation_rate": {"type": ["number", "null"], "minimum": 0},
        "capacity_estimated_round_trip_cost_bps": {"type": ["number", "null"], "minimum": 0},
        "capacity_max_supported_capital": {"type": ["number", "null"], "minimum": 0},
        "capacity_observation_count": {"type": "integer", "minimum": 0},
        "capacity_missing_observation_count": {"type": "integer", "minimum": 0},
        "stale": {"type": "boolean"},
        "failures": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "required": [
        "security_id",
        "strategy_id",
        "strategy_version",
        "validation_status",
        "as_of_date",
        "signal_date",
        "execution_date",
        "selected_security_ids",
        "current_security_selected",
        "current_security_rank",
        "current_security_momentum",
        "target_position_fraction",
        "current_security_target_fraction",
        "bars_until_next_rebalance",
        "base_total_return",
        "stress_total_return",
        "excess_return",
        "max_drawdown",
        "sharpe_ratio",
        "walk_forward_fold_count",
        "required_walk_forward_fold_count",
        "walk_forward_positive_ratio",
        "walk_forward_excess_ratio",
        "cumulative_turnover",
        "average_rebalance_turnover",
        "cumulative_transaction_cost",
        "trading_system",
        "capacity_status",
        "capacity_model_version",
        "capacity_reference_capital",
        "capacity_max_participation_rate",
        "capacity_estimated_round_trip_cost_bps",
        "capacity_max_supported_capital",
        "capacity_observation_count",
        "capacity_missing_observation_count",
        "stale",
        "failures",
        "notes"
      ],
      "additionalProperties": false,
      "description": "与单标的策略并行的组合级研究证据，不绕过最终门禁。"
    },
    "raw_signal": {
      "type": "string",
      "description": "风险处理前的原始策略信号。"
    },
    "final_signal": {
      "enum": [
        "BUY_CANDIDATE",
        "ADD_CANDIDATE",
        "HOLD",
        "REDUCE",
        "SELL",
        "WATCH",
        "ABSTAIN"
      ],
      "description": "经过数据、规则、风险和组合约束后的最终操作。"
    },
    "grade": {
      "type": [
        "string",
        "null"
      ],
      "description": "信号等级。"
    },
    "target_position_limit": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1,
      "description": "目标仓位上限，0至1。"
    },
    "positive_drivers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "支持当前判断的因素。"
    },
    "negative_drivers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "反对当前判断或风险因素。"
    },
    "exit_or_invalidation_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "退出或判断失效条件。"
    },
    "abstain_reason": {
      "type": [
        "string",
        "null"
      ],
      "description": "不交易原因。"
    }
  },
  "additionalProperties": false,
  "description": "面向用户的完整策略、预测、风险、操作与来源追踪结果。"
}
